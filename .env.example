# TradingView MCP — environment configuration
# Copy to `.env` (which is git-ignored) and fill in the values.

# --- Supabase (scan publishing) ---------------------------------------------
# Project URL from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role key (Project Settings → API → service_role).
# Server-side ONLY — it bypasses Row Level Security. Never ship it to a browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
